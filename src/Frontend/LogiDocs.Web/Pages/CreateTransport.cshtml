@page
@model LogiDocs.Web.Pages.CreateTransportModel
@{
    ViewData["Title"] = "Add shipping";
}

<h2>Adaugă transport</h2>

@if (Model.Error != null)
{
    <p style="color:red">@Model.Error</p>
}

<form method="post">
    <div class="mb-3">
        <label class="form-label">Reference</label>
        <input class="form-control" asp-for="Input.ReferenceNo" />
        <span class="text-danger" asp-validation-for="Input.ReferenceNo"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Origin</label>
        <input class="form-control" asp-for="Input.Origin" />
        <span class="text-danger" asp-validation-for="Input.Origin"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Destination</label>
        <input class="form-control" asp-for="Input.Destination" />
        <span class="text-danger" asp-validation-for="Input.Destination"></span>
    </div>

    <button class="btn btn-primary" type="submit">Salvează</button>
    <a class="btn btn-secondary" asp-page="/Transports">Înapoi</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}