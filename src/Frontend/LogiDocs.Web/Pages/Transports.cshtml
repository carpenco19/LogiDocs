@page
@model LogiDocs.Web.Pages.TransportsModel
@using LogiDocs.Web.Auth

@{
    ViewData["Title"] = "Transporturi";
}

<h2>Transporturi</h2>

@if (User.IsInRole(Roles.Carrier) || User.IsInRole(Roles.Administrator))
{
    <p>
        <a asp-page="/CreateTransport" class="btn btn-success btn-sm">Add shipping</a>
    </p>
}

@if (Model.Error != null)
{
    <p style="color:red">@Model.Error</p>
}
else if (Model.Items == null || Model.Items.Count == 0)
{
    <p>Nu există transporturi.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Reference</th>
                <th>Origin</th>
                <th>Destination</th>
                <th>Status</th>
                <th>Docs</th>
                <th>Verified</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Items)
            {
                <tr>
                    <td>
                        <a asp-page="/TransportDetails" asp-route-id="@t.Id">
                            @t.ReferenceNo
                        </a>
                    </td>

                    <td>@t.Origin</td>

                    <td>@t.Destination</td>

                    <td>
                        @if (t.Status == 0)
                        {
                            <span class="badge bg-secondary">Draft</span>
                        }
                        else if (t.Status == 1)
                        {
                            <span class="badge bg-warning text-dark">In Process</span>
                        }
                        else if (t.Status == 2)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else if (t.Status == 3)
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                        else
                        {
                            <span class="badge bg-dark">Unknown</span>
                        }
                    </td>

                    <td>@t.DocumentsCount</td>

                    <td>@t.VerifiedDocuments</td>

                    <td>
                        <a class="btn btn-primary btn-sm"
                           asp-page="/TransportDetails"
                           asp-route-id="@t.Id">
                            Open
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}