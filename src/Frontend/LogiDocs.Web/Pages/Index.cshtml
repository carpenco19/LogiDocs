@page
@model LogiDocs.Web.Pages.IndexModel
@using LogiDocs.Web.Auth

@{
    ViewData["Title"] = "Dashboard";

    var currentRole = "User";
    var roleDescription = "Authenticated user";
    var roleBadgeClass = "bg-secondary";

    if (User.IsInRole(Roles.Administrator))
    {
        currentRole = "Administrator";
        roleDescription = "Full access to configuration, monitoring, and operational workflows.";
        roleBadgeClass = "bg-dark";
    }
    else if (User.IsInRole(Roles.CustomsAuthority))
    {
        currentRole = "Customs Authority";
        roleDescription = "Validation of authenticity and customs-side verification workflows.";
        roleBadgeClass = "bg-danger";
    }
    else if (User.IsInRole(Roles.CustomsBroker))
    {
        currentRole = "Customs Broker";
        roleDescription = "Verification of documents and customs preparation activities.";
        roleBadgeClass = "bg-warning text-dark";
    }
    else if (User.IsInRole(Roles.Carrier))
    {
        currentRole = "Carrier";
        roleDescription = "Transport execution and transport document handling.";
        roleBadgeClass = "bg-info text-dark";
    }
    else if (User.IsInRole(Roles.Shipper))
    {
        currentRole = "Shipper";
        roleDescription = "Creation of transports and upload of commercial documents.";
        roleBadgeClass = "bg-success";
    }
}

<div class="app-page dashboard-home-page">
    <section class="dashboard-hero dashboard-hero--refined mb-4">
        <div class="dashboard-hero-overlay"></div>

        <div class="dashboard-hero-content dashboard-hero-content--refined">
            <div class="dashboard-hero-text dashboard-hero-text--refined">
                <div class="hero-badge mb-3">Logistics Document Platform</div>

                <h1 class="dashboard-hero-title">LogiDocs Dashboard</h1>

                <p class="dashboard-hero-subtitle">
                    Monitor transports, track document progress, and manage validation workflows in one place.
                </p>

                <div class="dashboard-actions mt-4">
                    <a asp-page="/Transports" class="btn btn-primary btn-lg dashboard-action-btn">
                        Open Transports
                    </a>

                    @if (User.IsInRole(Roles.Shipper) || User.IsInRole(Roles.Administrator))
                    {
                        <a asp-page="/CreateTransport" class="btn btn-success btn-lg dashboard-action-btn">
                            Create Transport
                        </a>
                    }

                    @if (User.IsInRole(Roles.Administrator))
                    {
                        <a asp-page="/AuditHistory" class="btn btn-outline-dark">
                            Open Audit History
                        </a>

                        <a asp-page="/Privacy" class="btn btn-outline-secondary">
                            Open Admin Overview
                        </a>
                    }

                    <a asp-page="/Index" class="btn btn-outline-light btn-lg dashboard-action-btn">
                        Refresh Dashboard
                    </a>
                </div>

                <div class="hero-inline-highlights">
                    <div class="hero-inline-highlight">
                        <span class="hero-inline-label">Current Role</span>
                        <strong>@currentRole</strong>
                    </div>

                    <div class="hero-inline-highlight">
                        <span class="hero-inline-label">Transports</span>
                        <strong>@Model.TotalTransports</strong>
                    </div>

                    <div class="hero-inline-highlight">
                        <span class="hero-inline-label">Verification</span>
                        <strong>@Model.VerificationPercent%</strong>
                    </div>
                </div>
            </div>

            <div class="hero-side-card hero-side-card--refined">
                <div class="hero-side-card-inner">
                    <div class="hero-side-label">Role Overview</div>
                    <div class="hero-side-title hero-side-title--compact">@currentRole</div>

                    <p class="hero-side-text">
                        @roleDescription
                    </p>

                    <div class="hero-role-pill-row">
                        @if (User.IsInRole(Roles.Shipper) || User.IsInRole(Roles.Administrator))
                        {
                            <span class="hero-role-pill">Create transport</span>
                        }

                        @if (User.IsInRole(Roles.Carrier) || User.IsInRole(Roles.Administrator))
                        {
                            <span class="hero-role-pill">Manage documents</span>
                        }

                        @if (User.IsInRole(Roles.CustomsBroker) || User.IsInRole(Roles.CustomsAuthority) || User.IsInRole(Roles.Administrator))
                        {
                            <span class="hero-role-pill">Review workflow</span>
                        }
                    </div>

                    <div class="hero-role-note">
                        Access to pages and actions is displayed according to the role assigned to your account.
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-section mb-4">
        <div class="stats-grid">
            <div class="modern-stat-card">
                <div class="modern-stat-label">Total Transports</div>
                <div class="modern-stat-value">@Model.TotalTransports</div>
            </div>

            <div class="modern-stat-card">
                <div class="modern-stat-label">Draft</div>
                <div class="modern-stat-value">@Model.DraftTransports</div>
            </div>

            <div class="modern-stat-card">
                <div class="modern-stat-label">In Process</div>
                <div class="modern-stat-value">@Model.InProcessTransports</div>
            </div>

            <div class="modern-stat-card">
                <div class="modern-stat-label">Completed</div>
                <div class="modern-stat-value">@Model.CompletedTransports</div>
            </div>

            <div class="modern-stat-card">
                <div class="modern-stat-label">Cancelled</div>
                <div class="modern-stat-value">@Model.CancelledTransports</div>
            </div>

            <div class="modern-stat-card">
                <div class="modern-stat-label">Total Documents</div>
                <div class="modern-stat-value">@Model.TotalDocuments</div>
            </div>

            <div class="modern-stat-card">
                <div class="modern-stat-label">Verified Documents</div>
                <div class="modern-stat-value">@Model.VerifiedDocuments</div>
            </div>

            <div class="modern-stat-card">
                <div class="modern-stat-label">Rejected Documents</div>
                <div class="modern-stat-value">@Model.RejectedDocuments</div>
            </div>
        </div>
    </section>

    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <section class="dashboard-card h-100">
                <div class="dashboard-card-header">
                    <div>
                        <h5 class="mb-1">Current Role</h5>
                        <p class="text-muted mb-0">The active role assigned to your account</p>
                    </div>
                </div>

                <div class="mt-3">
                    <span class="badge @roleBadgeClass px-3 py-2 fs-6">@currentRole</span>
                    <p class="text-muted mt-3 mb-0">@roleDescription</p>
                </div>
            </section>
        </div>

        <div class="col-lg-7">
            <section class="dashboard-card h-100">
                <div class="dashboard-card-header">
                    <div>
                        <h5 class="mb-1">Role-Based Quick Actions</h5>
                        <p class="text-muted mb-0">Available actions based on your assigned role</p>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a asp-page="/Transports" class="btn btn-outline-primary">
                        View Transports
                    </a>

                    @if (User.IsInRole(Roles.Shipper) || User.IsInRole(Roles.Administrator))
                    {
                        <a asp-page="/CreateTransport" class="btn btn-success">
                            Create Transport
                        </a>
                    }

                    @if (User.IsInRole(Roles.Carrier) || User.IsInRole(Roles.Administrator))
                    {
                        <a asp-page="/Transports" class="btn btn-outline-info">
                            Manage Transport Documents
                        </a>
                    }

                    @if (User.IsInRole(Roles.CustomsBroker) || User.IsInRole(Roles.CustomsAuthority) || User.IsInRole(Roles.Administrator))
                    {
                        <a asp-page="/Transports" class="btn btn-outline-warning">
                            Review Verification Flow
                        </a>
                    }

                    @if (User.IsInRole(Roles.Administrator))
                    {
                        <a asp-page="/Privacy" class="btn btn-outline-dark">
                            Open Admin Overview
                        </a>
                    }
                </div>
            </section>
        </div>
    </div>

    <section class="dashboard-card mb-4">
        <div class="dashboard-card-header">
            <div>
                <h5 class="mb-1">Verification Progress</h5>
                <p class="text-muted mb-0">Current document validation rate across all transports</p>
            </div>
            <div class="progress-label">@Model.VerificationPercent%</div>
        </div>

        <div class="mt-3">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Verified documents</span>
                <strong>@Model.VerifiedDocuments / @Model.TotalDocuments</strong>
            </div>

            <div class="progress logistics-progress" style="height: 18px;">
                <div class="progress-bar logistics-progress-bar"
                     role="progressbar"
                     style="width: @Model.VerificationPercent%;"
                     aria-valuenow="@Model.VerificationPercent"
                     aria-valuemin="0"
                     aria-valuemax="100">
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-card mb-4">
        <div class="dashboard-card-header">
            <div>
                <h5 class="mb-1">Recent Transports</h5>
                <p class="text-muted mb-0">Latest transport records and their document status</p>
            </div>
        </div>

        @if (Model.RecentTransports.Count == 0)
        {
            <p class="text-muted mb-0 mt-3">No transports available.</p>
        }
        else
        {
            <div class="table-responsive mt-3">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Origin</th>
                            <th>Destination</th>
                            <th>Status</th>
                            <th>Verified</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.RecentTransports)
                        {
                            <tr>
                                <td class="fw-semibold">@t.ReferenceNo</td>
                                <td>@t.Origin</td>
                                <td>@t.Destination</td>
                                <td>
                                    @if (t.Status == 0)
                                    {
                                        <span class="badge bg-secondary">Draft</span>
                                    }
                                    else if (t.Status == 1)
                                    {
                                        <span class="badge bg-warning text-dark">In Process</span>
                                    }
                                    else if (t.Status == 2)
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else if (t.Status == 3)
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                </td>
                                <td>@t.VerifiedDocuments / @t.DocumentsCount</td>
                                <td>
                                    <a class="btn btn-primary btn-sm"
                                       asp-page="/TransportDetails"
                                       asp-route-id="@t.Id">
                                        Open
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

<style>
    .dashboard-hero--refined {
        min-height: 0;
    }

    .dashboard-hero-content--refined {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
        align-items: center;
        gap: 28px;
        min-height: 0;
    }

    .dashboard-hero-text--refined {
        padding-right: 12px;
    }

    .hero-inline-highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 26px;
    }

    .hero-inline-highlight {
        min-width: 150px;
        padding: 16px 18px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.10);
        border: 1px solid rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(8px);
    }

    .hero-inline-label {
        display: block;
        color: rgba(255,255,255,0.72);
        font-size: 0.84rem;
        margin-bottom: 6px;
    }

    .hero-inline-highlight strong {
        color: #fff;
        font-size: 1.15rem;
        font-weight: 800;
    }

    .hero-side-card--refined {
        align-self: center;
    }

    .hero-side-title--compact {
        font-size: 2.1rem;
        line-height: 1.05;
        margin-bottom: 12px;
    }

    .hero-role-pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
    }

    .hero-role-pill {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.12);
        color: #fff;
        font-size: 0.88rem;
        font-weight: 700;
    }

    .hero-role-note {
        margin-top: 18px;
        padding-top: 16px;
        border-top: 1px solid rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.76);
        font-size: 0.94rem;
        line-height: 1.65;
    }

    @@media (max-width: 991.98px) {
        .dashboard-hero-content--refined {
            grid-template-columns: 1fr;
        }

        .dashboard-hero-text--refined {
            padding-right: 0;
        }

        .hero-side-title--compact {
            font-size: 1.8rem;
        }
    }

    @@media (max-width: 575.98px) {
        .hero-inline-highlights {
            flex-direction: column;
        }

        .hero-inline-highlight {
            width: 100%;
        }

        .hero-role-pill {
            width: 100%;
            justify-content: center;
        }
    }
</style>