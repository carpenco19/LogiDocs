@page "{id:guid}"
@model LogiDocs.Web.Pages.TransportDetailsModel

@{
    ViewData["Title"] = "Transport Details";
}

<h2>Transport Details</h2>

<p>
    <strong>Transport:</strong> @Model.TransportRef
</p>

<hr />

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <p style="color:red">@Model.Error</p>
}

@if (!User.Identity!.IsAuthenticated)
{
    <p style="color:#b00">
        Nu ești autentificat. Te rog mergi la
        <a href="/Identity/Account/Login">Login</a>.
    </p>
}
else
{
    @* ---------- UPLOAD ---------- *@

    @if (Model.CanUpload)
    {
        <h4>Upload New Document</h4>

        <form method="post"
              enctype="multipart/form-data"
              asp-page-handler="Upload">

            <div class="row g-2 align-items-end">

                <div class="col-md-4">
                    <label class="form-label">File</label>
                    <input class="form-control" type="file" asp-for="UploadFile" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Document Type</label>
                    <select class="form-select" asp-for="Type">
                        <option value="0">CMR</option>
                        <option value="1">Invoice</option>
                        <option value="2">PackingList</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-success">
                        Upload
                    </button>
                </div>

            </div>
        </form>

        <hr />
    }

    <h4>Documents</h4>

    @if (Model.Documents == null || Model.Documents.Count == 0)
    {
        <p>No documents for this transport.</p>
    }
    else
    {
        <table class="table table-striped">

            <thead>
                <tr>
                    <th>File Name</th>
                    <th>Type</th>
                    <th>Hash</th>
                    <th>Blockchain</th>
                    <th>Tx</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var d in Model.Documents)
                {
                    var registered = string.Equals(d.ChainStatus, "Registered",
                    StringComparison.OrdinalIgnoreCase);

                    <tr>

                        <td>@d.OriginalFileName</td>

                        <td>@d.Type</td>

                        <td style="max-width:380px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            @d.Sha256
                        </td>

                        <td>
                            @if (registered)
                            {
                                <span class="badge bg-success">Registered</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Not registered</span>
                            }
                        </td>

                        <td style="max-width:260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            @(string.IsNullOrWhiteSpace(d.BlockchainTxId) ? "-" : d.BlockchainTxId)
                        </td>

                        <td>

                            <a class="btn btn-primary btn-sm"
                               href="http://localhost:5006/api/documents/@d.Id/download">
                                Download
                            </a>

                            @if (Model.CanRegister && !registered)
                            {
                                <form method="post"
                                      asp-page-handler="Register"
                                      style="display:inline">

                                    <input type="hidden"
                                           asp-for="RegisterDocumentId"
                                           value="@d.Id" />

                                    <button type="submit"
                                            class="btn btn-success btn-sm">
                                        Register
                                    </button>

                                </form>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>
    }
}