@page
@model LogiDocs.Web.Pages.TransportDetailsModel
@{
    ViewData["Title"] = "Transport Details";
}

<h2>Transport Details</h2>

<div>
    <strong>Transport:</strong> @(Model.TransportRef ?? "Unknown")
</div>

<hr />

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <p style="color:red">@Model.Error</p>
}

@if (User.IsInRole("Shipper") || User.IsInRole("Carrier"))
{
    <h3>Upload New Document</h3>

    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="TransportId" value="@Model.Id" />

        <div style="display:flex; gap:12px; align-items:end; flex-wrap:wrap;">
            <div>
                <label>File</label><br />
                <input type="file" asp-for="UploadFile" />
            </div>

            <div>
                <label>Document Type</label><br />
                <select asp-for="Type" style="min-width:180px;">
                    <option value="0">CMR</option>
                    <option value="1">Invoice</option>
                    <option value="2">PackingList</option>
                    <option value="3">CustomsDeclaration</option>
                </select>
            </div>

            <div>
                <button type="submit">Upload</button>
            </div>
        </div>
    </form>

    <hr />
}

<h3>Documents</h3>

@if (Model.Documents == null || Model.Documents.Count == 0)
{
    <p>No documents for this transport.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Type</th>
                <th>Hash</th>
                <th>Blockchain</th>
                <th>Tx</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Documents)
            {
                var isRegistered = !string.IsNullOrWhiteSpace(d.BlockchainTxId);

                <tr>
                    <td>@d.OriginalFileName</td>
                    <td>@d.Type</td>

                    <td style="max-width:420px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                        @d.Sha256
                    </td>

                    <td>
                        @if (isRegistered)
                        {
                            <span style="padding:2px 6px; background:#198754; color:white; border-radius:4px;">
                                Registered
                            </span>
                        }
                        else
                        {
                            <span style="padding:2px 6px; background:#6c757d; color:white; border-radius:4px;">
                                Not registered
                            </span>
                        }
                    </td>

                    <td style="max-width:260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                        @(isRegistered ? d.BlockchainTxId : "-")
                    </td>

                    <td style="white-space:nowrap;">
                        <a class="btn btn-sm btn-primary" href="/api/Documents/@d.Id/download">Download</a>

                        @if (!isRegistered && (User.IsInRole("CustomsBroker") || User.IsInRole("Administrator")))
                        {
                            <form method="post" style="display:inline;">
                                <input type="hidden" asp-for="RegisterDocumentId" value="@d.Id" />
                                <button class="btn btn-sm btn-success" type="submit">Register</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}