@page "{id:guid}"
@model LogiDocs.Web.Pages.TransportDetailsModel

@{
    ViewData["Title"] = "Transport Details";

    var totalDocs = Model.Documents?.Count ?? 0;
    var verifiedDocs = Model.Documents?.Count(x => x.Status == 1) ?? 0;
    var rejectedDocs = Model.Documents?.Count(x => x.Status == 3) ?? 0;
    var tamperedDocs = Model.Documents?.Count(x => x.Status == 2) ?? 0;
    var uploadedDocs = Model.Documents?.Count(x => x.Status == 0) ?? 0;
    var verificationPercent = totalDocs == 0 ? 0 : (int)Math.Round((double)verifiedDocs * 100 / totalDocs);

    string verificationToneClass = "verification-neutral";
    string verificationBadgeText = "No verification result";

    if (Model.VerificationResult != null)
    {
        if (Model.VerificationResult.IsIntegrityValid)
        {
            verificationToneClass = "verification-valid";
            verificationBadgeText = "Integrity valid";
        }
        else
        {
            verificationToneClass = "verification-warning";
            verificationBadgeText = "Check required";
        }
    }
}

<div class="transport-details-page">
    <section class="details-hero">
        <div class="details-hero__overlay"></div>

        <div class="details-hero__content">
            <div class="details-hero__left">
                <div class="details-badge">Transport workspace</div>

                <h1>Transport Details</h1>

                <p class="details-subtitle">
                    View transport documents, track multimodal segments, and manage verification operations from a single page.
                </p>

                <div class="details-reference-card">
                    <div class="details-reference-label">Transport Reference</div>
                    <div class="details-reference-value">@Model.TransportRef</div>
                </div>

                <div class="details-route-summary">
                    <div class="route-point">
                        <span class="route-label">Origin</span>
                        <strong>@Model.TransportOrigin</strong>
                    </div>

                    <div class="route-arrow">→</div>

                    <div class="route-point">
                        <span class="route-label">Destination</span>
                        <strong>@Model.TransportDestination</strong>
                    </div>
                </div>

                <div class="details-role-actions">
                    <span class="role-chip role-chip--base">Access granted</span>

                    @if (Model.CanUpload)
                    {
                        <span class="role-chip role-chip--green">Upload documents</span>
                    }

                    @if (Model.CanVerify)
                    {
                        <span class="role-chip role-chip--amber">Verify documents</span>
                    }

                    @if (Model.CanRegister)
                    {
                        <span class="role-chip role-chip--blue">Register on chain</span>
                    }

                    @if (Model.CanValidate)
                    {
                        <span class="role-chip role-chip--dark">Validate / Reject</span>
                    }
                </div>
            </div>

            <div class="details-hero__right">
                <div class="hero-summary-card">
                    <div class="hero-summary-label">Transport Type</div>
                    <div class="hero-summary-value hero-summary-value--sm">
                        @(Model.IsMultimodal ? "Multimodal" : "Single mode")
                    </div>
                    <div class="hero-summary-text">
                        @(string.IsNullOrWhiteSpace(Model.ModesSummary) ? "No mode information available" : Model.ModesSummary)
                    </div>

                    <div class="hero-mini-stats">
                        <div class="hero-mini-stat">
                            <span>Segments</span>
                            <strong>@Model.SegmentCount</strong>
                        </div>
                        <div class="hero-mini-stat">
                            <span>Documents</span>
                            <strong>@totalDocs</strong>
                        </div>
                        <div class="hero-mini-stat">
                            <span>Verified</span>
                            <strong>@verifiedDocs</strong>
                        </div>
                        <div class="hero-mini-stat">
                            <span>Progress</span>
                            <strong>@verificationPercent%</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="details-stats-strip">
        <div class="strip-stat-card">
            <div class="strip-stat-label">Segments</div>
            <div class="strip-stat-value">@Model.SegmentCount</div>
        </div>

        <div class="strip-stat-card">
            <div class="strip-stat-label">Uploaded</div>
            <div class="strip-stat-value">@uploadedDocs</div>
        </div>

        <div class="strip-stat-card">
            <div class="strip-stat-label">Verified</div>
            <div class="strip-stat-value text-success">@verifiedDocs</div>
        </div>

        <div class="strip-stat-card">
            <div class="strip-stat-label">Rejected</div>
            <div class="strip-stat-value text-danger">@rejectedDocs</div>
        </div>

        <div class="strip-stat-card">
            <div class="strip-stat-label">Tampered</div>
            <div class="strip-stat-value text-warning">@tamperedDocs</div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="modern-alert modern-alert-danger">
            <strong>Operation failed.</strong>
            <span>@Model.Error</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="modern-alert modern-alert-success">
            <strong>Success.</strong>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    <section class="details-card mb-4">
        <div class="details-card-header">
            <div>
                <h5 class="mb-1">Transport Segments</h5>
                <p class="text-muted mb-0">Stages that define the multimodal route of the current transport</p>
            </div>
            <div class="table-counter">@Model.SegmentCount total</div>
        </div>

        @if (Model.Segments == null || Model.Segments.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">🧭</div>
                <h6>No segments available</h6>
                <p class="text-muted mb-0">This transport does not yet contain explicit segment information.</p>
            </div>
        }
        else
        {
            <div class="segments-grid mt-4">
                @foreach (var s in Model.Segments.OrderBy(x => x.OrderNo))
                {
                    <div class="segment-card">
                        <div class="segment-card-top">
                            <div class="segment-step">Segment @s.OrderNo</div>
                            <div class="segment-mode-pill">@s.ModeName</div>
                        </div>

                        <div class="segment-route">
                            <div class="segment-point">
                                <span class="segment-point-label">Origin</span>
                                <strong>@s.Origin</strong>
                            </div>

                            <div class="segment-route-arrow">→</div>

                            <div class="segment-point">
                                <span class="segment-point-label">Destination</span>
                                <strong>@s.Destination</strong>
                            </div>
                        </div>

                        <div class="segment-operator">
                            <span>Operator</span>
                            <strong>@(string.IsNullOrWhiteSpace(s.OperatorName) ? "-" : s.OperatorName)</strong>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    @if (Model.VerificationResult != null)
    {
        <section class="details-card mb-4">
            <div class="details-card-header">
                <div>
                    <h5 class="mb-1">Verification Result</h5>
                    <p class="text-muted mb-0">Latest verification details for the selected document</p>
                </div>

                <div class="verification-badge @verificationToneClass">
                    @verificationBadgeText
                </div>
            </div>

            <div class="verification-grid mt-4">
                <div class="verification-item">
                    <div class="verification-label">Document</div>
                    <div class="verification-value">@Model.VerificationResult.OriginalFileName</div>
                </div>

                <div class="verification-item">
                    <div class="verification-label">Blockchain Status</div>
                    <div class="verification-value">
                        @(string.IsNullOrWhiteSpace(Model.VerificationResult.ChainStatus) ? "-" : Model.VerificationResult.ChainStatus)
                    </div>
                </div>

                <div class="verification-item">
                    <div class="verification-label">Registered At</div>
                    <div class="verification-value">
                        @(Model.VerificationResult.RegisteredOnChainAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")
                    </div>
                </div>

                <div class="verification-item">
                    <div class="verification-label">Integrity</div>
                    <div class="verification-value">
                        @(Model.VerificationResult.IsIntegrityValid ? "Yes" : "No")
                    </div>
                </div>

                <div class="verification-item verification-item--wide">
                    <div class="verification-label">Hash</div>
                    <div class="verification-value verification-code">@Model.VerificationResult.Sha256</div>
                </div>

                <div class="verification-item verification-item--wide">
                    <div class="verification-label">Blockchain Transaction</div>
                    <div class="verification-value verification-code">
                        @(string.IsNullOrWhiteSpace(Model.VerificationResult.BlockchainTxId) ? "-" : Model.VerificationResult.BlockchainTxId)
                    </div>
                </div>

                <div class="verification-item verification-item--wide">
                    <div class="verification-label">Message</div>
                    <div class="verification-value">@Model.VerificationResult.VerificationMessage</div>
                </div>
            </div>
        </section>
    }

    @if (Model.CanUpload)
    {
        <section class="details-card details-card--upload mb-4">
            <div class="details-card-header">
                <div>
                    <h5 class="mb-1">Upload New Document</h5>
                    <p class="text-muted mb-0">Attach a new document to the current transport record</p>
                </div>
            </div>

            <form method="post" enctype="multipart/form-data" asp-page-handler="Upload" class="upload-form mt-4">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-5">
                        <label class="form-label-modern">File</label>
                        <input class="form-control form-control-modern" type="file" asp-for="UploadFile" />
                    </div>

                    <div class="col-lg-4">
                        <label class="form-label-modern">Document Type</label>
                        <select class="form-select form-control-modern" asp-for="Type">
                            <option value="0">CMR</option>
                            <option value="1">Invoice</option>
                            <option value="2">Packing List</option>
                        </select>
                    </div>

                    <div class="col-lg-3">
                        <button type="submit" class="btn btn-success w-100 btn-action-modern">
                            Upload Document
                        </button>
                    </div>
                </div>
            </form>
        </section>
    }

    <section class="details-card">
        <div class="details-card-header">
            <div>
                <h5 class="mb-1">Documents</h5>
                <p class="text-muted mb-0">Attached files, statuses, blockchain information, and available actions</p>
            </div>
            <div class="table-counter">@totalDocs total</div>
        </div>

        @if (Model.Documents == null || Model.Documents.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">📄</div>
                <h6>No documents for this transport</h6>
                <p class="text-muted mb-0">Once files are uploaded, they will appear here together with validation and blockchain details.</p>
            </div>
        }
        else
        {
            <div class="table-responsive mt-4">
                <table class="table modern-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="file-col">File Name</th>
                            <th>Type</th>
                            <th>Doc Status</th>
                            <th>Hash</th>
                            <th>Blockchain</th>
                            <th>Tx</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var d in Model.Documents)
                        {
                            var chainStatus = d.ChainStatus?.Trim();
                            var isRegistered = string.Equals(chainStatus, "Registered", StringComparison.OrdinalIgnoreCase);
                            var isPending = string.Equals(chainStatus, "Pending", StringComparison.OrdinalIgnoreCase);
                            var isFailed = string.Equals(chainStatus, "Failed", StringComparison.OrdinalIgnoreCase);

                            var isUploaded = d.Status == 0;
                            var isVerified = d.Status == 1;
                            var isTampered = d.Status == 2;
                            var isRejected = d.Status == 3;

                            <tr>
                                <td class="file-col">
                                    <div class="doc-file-cell">
                                        <div class="doc-file-name">@d.OriginalFileName</div>
                                        <div class="doc-file-subtitle">Document ID: @d.Id</div>
                                    </div>
                                </td>

                                <td>
                                    <span class="type-pill">@d.TypeName</span>
                                </td>

                                <td>
                                    @if (isVerified)
                                    {
                                        <span class="status-pill status-pill--success">Verified</span>
                                    }
                                    else if (isTampered)
                                    {
                                        <span class="status-pill status-pill--danger">Tampered</span>
                                    }
                                    else if (isRejected)
                                    {
                                        <span class="status-pill status-pill--dark">Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill status-pill--muted">Uploaded</span>
                                    }
                                </td>

                                <td class="hash-cell">
                                    <span class="text-truncate d-inline-block">@d.Sha256</span>
                                </td>

                                <td>
                                    @if (isRegistered)
                                    {
                                        <span class="status-pill status-pill--success">Registered</span>
                                    }
                                    else if (isPending)
                                    {
                                        <span class="status-pill status-pill--warning">Pending</span>
                                    }
                                    else if (isFailed)
                                    {
                                        <span class="status-pill status-pill--danger">Failed</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill status-pill--muted">Not registered</span>
                                    }
                                </td>

                                <td class="hash-cell">
                                    <span class="text-truncate d-inline-block">
                                        @(string.IsNullOrWhiteSpace(d.BlockchainTxId) ? "-" : d.BlockchainTxId)
                                    </span>
                                </td>

                                <td class="actions-cell">
                                    <div class="action-stack">
                                        <a class="btn btn-primary btn-sm btn-table-action"
                                           href="http://localhost:5006/api/documents/@d.Id/download">
                                            Download
                                        </a>

                                        @if (Model.CanRegister && !isRegistered && !isPending)
                                        {
                                            <form method="post" asp-page-handler="Register" class="d-inline">
                                                <input type="hidden" asp-for="RegisterDocumentId" value="@d.Id" />
                                                <button type="submit" class="btn btn-success btn-sm btn-table-action">
                                                    Register
                                                </button>
                                            </form>
                                        }

                                        @if (Model.CanVerify)
                                        {
                                            <form method="post" asp-page-handler="Verify" class="d-inline">
                                                <input type="hidden" asp-for="VerifyDocumentId" value="@d.Id" />
                                                <button type="submit" class="btn btn-warning btn-sm btn-table-action">
                                                    Verify
                                                </button>
                                            </form>
                                        }

                                        @if (Model.CanValidate && isUploaded)
                                        {
                                            <form method="post" asp-page-handler="Validate" class="d-inline">
                                                <input type="hidden" asp-for="ValidateDocumentId" value="@d.Id" />
                                                <button type="submit"
                                                        class="btn btn-dark btn-sm btn-table-action"
                                                        onclick="return confirm('Are you sure you want to validate this document?');">
                                                    Validate
                                                </button>
                                            </form>

                                            <form method="post" asp-page-handler="Reject" class="d-inline">
                                                <input type="hidden" asp-for="RejectDocumentId" value="@d.Id" />
                                                <button type="submit"
                                                        class="btn btn-danger btn-sm btn-table-action"
                                                        onclick="return confirm('Are you sure you want to reject this document?');">
                                                    Reject
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

<style>
    .transport-details-page {
        padding: 8px 0 24px;
        background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.10), transparent 24%), radial-gradient(circle at bottom left, rgba(16, 185, 129, 0.08), transparent 20%);
    }

    .details-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        margin-bottom: 22px;
        background: linear-gradient(135deg, #0f172a 0%, #172554 48%, #2563eb 100%);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.20);
    }

    .details-hero__overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.14), transparent 20%), radial-gradient(circle at 80% 80%, rgba(255,255,255,0.08), transparent 18%);
        pointer-events: none;
    }

    .details-hero__content {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 24px;
        padding: 34px;
        color: #fff;
    }

    .details-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.14);
        font-size: 0.9rem;
        font-weight: 700;
        margin-bottom: 18px;
        backdrop-filter: blur(8px);
    }

    .details-hero h1 {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 14px;
    }

    .details-subtitle {
        max-width: 720px;
        color: rgba(255, 255, 255, 0.84);
        font-size: 1.04rem;
        line-height: 1.8;
        margin-bottom: 22px;
    }

    .details-reference-card {
        display: inline-block;
        min-width: 260px;
        padding: 18px 20px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.10);
        border: 1px solid rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(8px);
        margin-bottom: 16px;
    }

    .details-reference-label {
        color: rgba(255,255,255,0.72);
        font-size: 0.92rem;
        margin-bottom: 6px;
    }

    .details-reference-value {
        font-size: 1.45rem;
        font-weight: 800;
        line-height: 1.2;
    }

    .details-route-summary {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 14px;
        margin-bottom: 18px;
    }

    .route-point {
        padding: 12px 16px;
        border-radius: 18px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.12);
    }

    .route-label {
        display: block;
        color: rgba(255,255,255,0.72);
        font-size: 0.82rem;
        margin-bottom: 4px;
    }

    .route-point strong {
        color: #fff;
        font-size: 1rem;
        font-weight: 800;
    }

    .route-arrow {
        font-size: 1.2rem;
        font-weight: 800;
        color: rgba(255,255,255,0.82);
    }

    .details-role-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .role-chip {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 700;
    }

    .role-chip--base {
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.14);
        color: #fff;
    }

    .role-chip--green {
        background: rgba(34, 197, 94, 0.18);
        color: #dcfce7;
        border: 1px solid rgba(34, 197, 94, 0.24);
    }

    .role-chip--amber {
        background: rgba(245, 158, 11, 0.20);
        color: #fef3c7;
        border: 1px solid rgba(245, 158, 11, 0.24);
    }

    .role-chip--blue {
        background: rgba(59, 130, 246, 0.22);
        color: #dbeafe;
        border: 1px solid rgba(59, 130, 246, 0.22);
    }

    .role-chip--dark {
        background: rgba(15, 23, 42, 0.26);
        color: #ffffff;
        border: 1px solid rgba(255,255,255,0.14);
    }

    .hero-summary-card {
        height: 100%;
        padding: 24px;
        border-radius: 26px;
        background: rgba(255, 255, 255, 0.10);
        border: 1px solid rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(10px);
    }

    .hero-summary-label {
        color: rgba(255,255,255,0.75);
        font-size: 0.92rem;
        margin-bottom: 8px;
    }

    .hero-summary-value {
        font-size: 3rem;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 8px;
    }

    .hero-summary-value--sm {
        font-size: 2.2rem;
    }

    .hero-summary-text {
        color: rgba(255,255,255,0.78);
        line-height: 1.7;
        margin-bottom: 4px;
    }

    .hero-mini-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        margin-top: 20px;
    }

    .hero-mini-stat {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.12);
    }

        .hero-mini-stat span {
            display: block;
            color: rgba(255,255,255,0.72);
            font-size: 0.86rem;
            margin-bottom: 4px;
        }

        .hero-mini-stat strong {
            font-size: 1.15rem;
            font-weight: 800;
            color: #fff;
        }

    .details-stats-strip {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 14px;
        margin-bottom: 22px;
    }

    .strip-stat-card {
        border-radius: 22px;
        padding: 18px 20px;
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(226, 232, 240, 0.92);
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
        backdrop-filter: blur(12px);
    }

    .strip-stat-label {
        color: #64748b;
        font-size: 0.9rem;
        margin-bottom: 10px;
    }

    .strip-stat-value {
        font-size: 1.95rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
    }

    .modern-alert {
        display: flex;
        gap: 8px;
        align-items: flex-start;
        border-radius: 18px;
        padding: 14px 18px;
        margin-bottom: 18px;
        border: 1px solid transparent;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    }

        .modern-alert strong {
            font-weight: 800;
        }

    .modern-alert-success {
        background: #ecfdf5;
        border-color: #a7f3d0;
        color: #065f46;
    }

    .modern-alert-danger {
        background: #fff1f2;
        border-color: #fecdd3;
        color: #be123c;
    }

    .details-card {
        border-radius: 28px;
        padding: 26px;
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(226, 232, 240, 0.92);
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.08);
        backdrop-filter: blur(12px);
    }

    .details-card--upload {
        background: linear-gradient(180deg, rgba(255,255,255,0.92) 0%, rgba(248,251,255,0.92) 100%);
    }

    .details-card-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
    }

        .details-card-header h5 {
            font-weight: 800;
            color: #0f172a;
        }

    .table-counter {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        background: #e0ecff;
        color: #1d4ed8;
        font-weight: 800;
        font-size: 0.9rem;
        white-space: nowrap;
    }

    .segments-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

