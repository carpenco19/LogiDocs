@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy";
}

<div class="privacy-page">
    <section class="privacy-hero">
        <div class="privacy-hero__content">
            <div class="privacy-badge">LogiDocs • Privacy Policy</div>

            <h1>Data protection and document confidentiality</h1>

            <p class="privacy-subtitle">
                LogiDocs manages logistics and customs documents in a controlled environment,
                with focus on traceability, restricted access, and preservation of data integrity.
            </p>

            <div class="privacy-actions">
                <a asp-page="/Index" class="btn-main">Back to home page</a>
                <a asp-page="/Transports" class="btn-secondary">View transports</a>
            </div>
        </div>
    </section>

    <section class="privacy-grid">
        <article class="privacy-card privacy-card--wide">
            <div class="card-icon">🔒</div>
            <h2>What data is processed</h2>
            <p>
                The platform may process data related to transports, commercial documents,
                transport documents, upload metadata, document status, and users interacting
                with the system.
            </p>
            <ul>
                <li>data about the shipper, carrier, and customs broker;</li>
                <li>information contained in commercial and logistics documents;</li>
                <li>upload date, change history, and validation status;</li>
                <li>technical identifiers required for audit and traceability.</li>
            </ul>
        </article>

        <article class="privacy-card">
            <div class="card-icon">📄</div>
            <h2>Purpose of use</h2>
            <p>
                Data is used for uploading, organizing, verifying, and monitoring documents
                related to multimodal transport, as well as for supporting validation and audit processes.
            </p>
        </article>

        <article class="privacy-card">
            <div class="card-icon">🛡️</div>
            <h2>Protection measures</h2>
            <p>
                Access to information is granted based on user roles, and data is stored
                in a centralized system where document-related actions and changes can be tracked.
            </p>
        </article>

        <article class="privacy-card">
            <div class="card-icon">⛓️</div>
            <h2>Integrity and traceability</h2>
            <p>
                For certain operations, the system may store digital fingerprints of documents
                for authenticity verification and detection of later modifications.
            </p>
        </article>

        <article class="privacy-card">
            <div class="card-icon">👤</div>
            <h2>User rights</h2>
            <p>
                The user may request verification of visible account data, correction of inaccurate
                information, and clarification regarding the way uploaded documents are processed.
            </p>
        </article>

        <article class="privacy-card privacy-card--wide">
            <div class="card-icon">📌</div>
            <h2>Operational responsibility</h2>
            <p>
                Each user category in the platform has access only to the actions and information
                required by its role. The administrator can monitor the history of operations,
                while authorities or logistics actors may verify documents within the limits allowed by the system.
            </p>
        </article>
    </section>

    <section class="privacy-highlight">
        <div class="highlight-box">
            <h3>Note</h3>
            <p>
                This page has an informational role and describes the general way data is handled in LogiDocs.
                The content may later be extended with internal policies, legal terms, and additional rules
                regarding document retention and sharing.
            </p>
        </div>
    </section>
</div>

<style>
    .privacy-page {
        padding: 24px 0 48px;
        background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.10), transparent 24%), radial-gradient(circle at bottom left, rgba(16, 185, 129, 0.08), transparent 22%);
    }

    .privacy-hero {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 48px 36px;
        margin-bottom: 28px;
        background: linear-gradient(135deg, #0f172a 0%, #16213e 55%, #1d4ed8 100%);
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.20);
        color: #fff;
    }

    .privacy-hero__content {
        position: relative;
        z-index: 2;
        max-width: 820px;
    }

    .privacy-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        border: 1px solid rgba(255, 255, 255, 0.18);
        font-size: 0.92rem;
        font-weight: 600;
        margin-bottom: 18px;
        backdrop-filter: blur(8px);
    }

    .privacy-hero h1 {
        font-size: 2.4rem;
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 16px;
    }

    .privacy-subtitle {
        font-size: 1.05rem;
        line-height: 1.75;
        color: rgba(255, 255, 255, 0.88);
        max-width: 760px;
        margin-bottom: 24px;
    }

    .privacy-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .btn-main,
    .btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.2s ease;
    }

    .btn-main {
        background: #ffffff;
        color: #0f172a;
        box-shadow: 0 10px 24px rgba(255, 255, 255, 0.18);
    }

        .btn-main:hover {
            color: #0f172a;
            transform: translateY(-1px);
        }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.10);
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.18);
    }

        .btn-secondary:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.16);
            transform: translateY(-1px);
        }

    .privacy-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 20px;
        margin-bottom: 28px;
    }

    .privacy-card {
        grid-column: span 6;
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(226, 232, 240, 0.9);
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.07);
        backdrop-filter: blur(10px);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .privacy-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.10);
        }

    .privacy-card--wide {
        grid-column: span 12;
    }

    .card-icon {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 16px;
        font-size: 1.4rem;
        background: linear-gradient(135deg, #dbeafe 0%, #ecfeff 100%);
        margin-bottom: 16px;
    }

    .privacy-card h2 {
        font-size: 1.22rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 12px;
    }

    .privacy-card p {
        color: #475569;
        line-height: 1.75;
        margin-bottom: 0;
    }

    .privacy-card ul {
        margin-top: 14px;
        margin-bottom: 0;
        padding-left: 18px;
        color: #475569;
    }

    .privacy-card li {
        margin-bottom: 8px;
        line-height: 1.65;
    }

    .privacy-highlight {
        margin-top: 8px;
    }

    .highlight-box {
        border-radius: 24px;
        padding: 24px 26px;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.96) 0%, rgba(30, 41, 59, 0.96) 100%);
        color: #fff;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.16);
    }

        .highlight-box h3 {
            font-size: 1.1rem;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .highlight-box p {
            margin-bottom: 0;
            color: rgba(255, 255, 255, 0.86);
            line-height: 1.75;
        }

    @@media (max-width: 991.98px) {
        .privacy-hero {
            padding: 34px 22px;
            border-radius: 22px;
        }

            .privacy-hero h1 {
                font-size: 2rem;
            }

        .privacy-card,
        .privacy-card--wide {
            grid-column: span 12;
        }
    }

    @@media (max-width: 575.98px) {
        .privacy-page {
            padding-top: 12px;
        }

        .privacy-hero h1 {
            font-size: 1.75rem;
        }

        .privacy-subtitle {
            font-size: 0.98rem;
        }

        .btn-main,
        .btn-secondary {
            width: 100%;
        }
    }
</style>