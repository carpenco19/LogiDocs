@using Microsoft.AspNetCore.Identity
@using LogiDocs.Web.Auth
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav auth-nav-custom">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item auth-user-item">
            <span class="auth-user-chip">
                <span class="auth-user-dot"></span>
                @UserManager.GetUserName(User)
            </span>
        </li>

        <li class="nav-item auth-logout-item">
            <form class="auth-logout-form" asp-area="Identity" asp-page="/Account/Logout" method="post">
                <button type="submit" class="auth-btn auth-btn-logout">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item auth-register-item">
            <a class="auth-btn auth-btn-register" asp-area="Identity" asp-page="/Account/Register">
                Register
            </a>
        </li>

        <li class="nav-item auth-login-item">
            <a class="auth-btn auth-btn-login" asp-area="Identity" asp-page="/Account/Login">
                Login
            </a>
        </li>
    }
</ul>

<style>
    .auth-nav-custom {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-left: 8px;
        margin-bottom: 0;
        padding-left: 0;
        list-style: none;
    }

    .auth-user-item,
    .auth-login-item,
    .auth-register-item,
    .auth-logout-item {
        display: flex;
        align-items: center;
    }

    .auth-user-chip {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        background: rgba(37, 99, 235, 0.08);
        border: 1px solid rgba(37, 99, 235, 0.14);
        color: #0f172a;
        font-weight: 700;
        font-size: 0.95rem;
        white-space: nowrap;
    }

    .auth-user-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.14);
        flex-shrink: 0;
    }

    .auth-logout-form {
        margin: 0;
    }

    .auth-btn {
        min-height: 42px;
        padding: 0 18px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        cursor: pointer;
        white-space: nowrap;
        line-height: 1;
    }

    .auth-btn-register {
        background: #ffffff;
        color: #1d4ed8 !important;
        border: 1px solid #bfdbfe;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.06);
    }

        .auth-btn-register:hover {
            color: #1d4ed8 !important;
            background: #f0f7ff;
            transform: translateY(-1px);
        }

    .auth-btn-login {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: #ffffff !important;
        border: none;
        box-shadow: 0 12px 24px rgba(37, 99, 235, 0.20);
    }

        .auth-btn-login:hover {
            color: #ffffff !important;
            transform: translateY(-1px);
            box-shadow: 0 16px 28px rgba(37, 99, 235, 0.26);
        }

    .auth-btn-logout {
        background: #ffffff;
        color: #0f172a;
        border: 1px solid #dbe3ef;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.06);
    }

        .auth-btn-logout:hover {
            background: #f8fbff;
            border-color: #bfdbfe;
            color: #0f172a;
            transform: translateY(-1px);
        }

    @@media (max-width: 991.98px) {
        .auth-nav-custom {
            margin-top: 12px;
            gap: 10px;
            flex-wrap: wrap;
            width: 100%;
        }
    }

    @@media (max-width: 575.98px) {
        .auth-nav-custom {
            width: 100%;
            align-items: stretch;
        }

        .auth-user-item,
        .auth-login-item,
        .auth-register-item,
        .auth-logout-item,
        .auth-logout-form {
            width: 100%;
        }

        .auth-user-chip,
        .auth-btn {
            width: 100%;
        }
    }
</style>