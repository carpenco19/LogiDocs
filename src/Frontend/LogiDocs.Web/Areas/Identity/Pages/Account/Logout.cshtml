@page
@model LogiDocs.Web.Areas.Identity.Pages.Account.LogoutModel

@{
    ViewData["Title"] = "Log out";
}

<div class="logout-page">
    <div class="container">
        <div class="logout-shell">

            <section class="logout-card">
                <div class="logout-badge">Session ended</div>

                <div class="logout-icon">✓</div>

                <h1>You have been logged out</h1>

                <p class="logout-text">
                    Your session has been closed successfully.
                    You can log in again at any time or return to the main LogiDocs pages.
                </p>

                <div class="logout-actions">
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-primary-modern">
                        Log in again
                    </a>

                    <a asp-area="" asp-page="/Index" class="btn-secondary-modern">
                        Back to dashboard
                    </a>
                </div>

                <div class="logout-links">
                    <a asp-area="" asp-page="/Privacy" class="link-tile">
                        <strong>Privacy policy</strong>
                        <span>Review how LogiDocs handles data and confidentiality.</span>
                    </a>

                    <a asp-area="" asp-page="/Transports" class="link-tile">
                        <strong>Transport overview</strong>
                        <span>Return to the transport management section.</span>
                    </a>
                </div>
            </section>

        </div>
    </div>
</div>

<style>
    .logout-page {
        min-height: calc(100vh - 80px);
        padding: 40px 0;
        display: flex;
        align-items: center;
        background: radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 28%), radial-gradient(circle at bottom right, rgba(16, 185, 129, 0.10), transparent 24%), linear-gradient(180deg, #f8fafc 0%, #edf4ff 100%);
    }

    .logout-shell {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .logout-card {
        width: 100%;
        max-width: 760px;
        padding: 42px;
        border-radius: 32px;
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(226, 232, 240, 0.95);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.10);
        backdrop-filter: blur(14px);
        text-align: center;
    }

    .logout-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: #e0ecff;
        color: #1d4ed8;
        font-size: 0.88rem;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .logout-icon {
        width: 84px;
        height: 84px;
        margin: 0 auto 20px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        box-shadow: 0 18px 36px rgba(37, 99, 235, 0.25);
    }

    .logout-card h1 {
        font-size: 2.4rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 14px;
        line-height: 1.15;
    }

    .logout-text {
        max-width: 560px;
        margin: 0 auto 28px;
        color: #64748b;
        font-size: 1.03rem;
        line-height: 1.8;
    }

    .logout-actions {
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 26px;
    }

    .btn-primary-modern,
    .btn-secondary-modern {
        min-height: 52px;
        padding: 0 22px;
        border-radius: 16px;
        text-decoration: none;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

    .btn-primary-modern {
        color: #fff;
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        box-shadow: 0 16px 30px rgba(37, 99, 235, 0.22);
    }

        .btn-primary-modern:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 20px 36px rgba(37, 99, 235, 0.28);
        }

    .btn-secondary-modern {
        color: #0f172a;
        background: #f8fbff;
        border: 1px solid #dbe7f5;
    }

        .btn-secondary-modern:hover {
            color: #0f172a;
            background: #f1f7ff;
            border-color: #bfdbfe;
            transform: translateY(-1px);
        }

    .logout-links {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
        margin-top: 8px;
    }

    .link-tile {
        text-align: left;
        text-decoration: none;
        padding: 18px 20px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background: #f8fbff;
        transition: all 0.2s ease;
    }

        .link-tile strong {
            display: block;
            color: #0f172a;
            font-size: 1rem;
            margin-bottom: 6px;
        }

        .link-tile span {
            color: #64748b;
            font-size: 0.94rem;
            line-height: 1.6;
        }

        .link-tile:hover {
            transform: translateY(-2px);
            border-color: #bfdbfe;
            background: #f0f7ff;
        }

    @@media (max-width: 767.98px) {
        .logout-page {
            min-height: auto;
            padding: 20px 0 32px;
        }

        .logout-card {
            padding: 26px;
            border-radius: 24px;
        }

            .logout-card h1 {
                font-size: 1.9rem;
            }

        .logout-links {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 575.98px) {
        .logout-actions {
            flex-direction: column;
        }

        .btn-primary-modern,
        .btn-secondary-modern {
            width: 100%;
        }
    }
</style>