@page
@model LogiDocs.Web.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Register";
}

<div class="register-page">
    <div class="container">
        <div class="register-shell">

            <section class="register-brand-panel">
                <div class="brand-badge">LogiDocs</div>

                <h1>Create your account</h1>

                <p class="brand-text">
                    Register to access a modern environment for managing logistics and customs documents,
                    with secure authentication, traceability, and structured workflows.
                </p>

                <div class="brand-features">
                    <div class="brand-feature">
                        <span class="feature-icon">📦</span>
                        <div>
                            <strong>Transport workflows</strong>
                            <p>Manage documents related to shipments and multimodal operations.</p>
                        </div>
                    </div>

                    <div class="brand-feature">
                        <span class="feature-icon">🔐</span>
                        <div>
                            <strong>Protected access</strong>
                            <p>Create a secure account to work in a controlled digital space.</p>
                        </div>
                    </div>

                    <div class="brand-feature">
                        <span class="feature-icon">📑</span>
                        <div>
                            <strong>Organized records</strong>
                            <p>Keep files, actions, and document handling clearly structured.</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="register-form-panel">
                <div class="register-card">
                    <div class="register-card-header">
                        <div class="register-mini-badge">New account</div>
                        <h2>Register in LogiDocs</h2>
                        <p>
                            Fill in the form below to create your account and enter the platform.
                        </p>
                    </div>

                    <form id="registerForm" method="post" asp-route-returnUrl="@Model.ReturnUrl">
                        <div asp-validation-summary="ModelOnly" class="validation-summary text-danger" role="alert"></div>

                        <div class="form-group-modern">
                            <label asp-for="Input.Email" class="form-label-modern"></label>
                            <input asp-for="Input.Email"
                                   class="form-control-modern"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="Enter your email" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Input.Role" class="form-label-modern"></label>
                            <select asp-for="Input.Role" class="form-control-modern form-select-modern" aria-required="true">
                                <option value="">Select your role</option>
                                @foreach (var role in Model.AllowedSelfRegistrationRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <span asp-validation-for="Input.Role" class="text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Input.Password" class="form-label-modern"></label>
                            <input asp-for="Input.Password"
                                   class="form-control-modern"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Create a password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Input.ConfirmPassword" class="form-label-modern"></label>
                            <input asp-for="Input.ConfirmPassword"
                                   class="form-control-modern"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Confirm your password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button id="registerSubmit" type="submit" class="btn-register-modern">
                            Create account
                        </button>

                        <div class="register-divider">
                            <span>Navigation</span>
                        </div>

                        <div class="register-links">
                            <a asp-area="Identity" asp-page="/Account/Login" class="secondary-link-card">
                                <strong>Already have an account?</strong>
                                <span>Go to the login page and access the platform.</span>
                            </a>

                            <a asp-area="" asp-page="/Privacy" class="secondary-link-card">
                                <strong>Privacy policy</strong>
                                <span>Review how LogiDocs handles data and confidentiality.</span>
                            </a>
                        </div>
                    </form>
                </div>
            </section>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .register-page {
        min-height: calc(100vh - 80px);
        padding: 32px 0;
        display: flex;
        align-items: center;
        background: radial-gradient(circle at top left, rgba(59, 130, 246, 0.14), transparent 28%), radial-gradient(circle at bottom right, rgba(16, 185, 129, 0.10), transparent 26%), linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    }

    .register-shell {
        width: 100%;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 28px;
        align-items: stretch;
    }

    .register-brand-panel {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 42px;
        background: linear-gradient(145deg, #0f172a 0%, #172554 55%, #2563eb 100%);
        color: #fff;
        box-shadow: 0 24px 70px rgba(15, 23, 42, 0.22);
    }

    .brand-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.16);
        font-size: 0.9rem;
        font-weight: 700;
        margin-bottom: 24px;
        backdrop-filter: blur(8px);
    }

    .register-brand-panel h1 {
        font-size: 2.8rem;
        line-height: 1.1;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .brand-text {
        max-width: 560px;
        color: rgba(255, 255, 255, 0.84);
        font-size: 1.05rem;
        line-height: 1.8;
        margin-bottom: 34px;
    }

    .brand-features {
        display: grid;
        gap: 16px;
        margin-top: 20px;
    }

    .brand-feature {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 18px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.10);
        backdrop-filter: blur(8px);
    }

    .feature-icon {
        width: 44px;
        height: 44px;
        min-width: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.14);
        font-size: 1.15rem;
    }

    .brand-feature strong {
        display: block;
        font-size: 1rem;
        margin-bottom: 4px;
    }

    .brand-feature p {
        margin: 0;
        color: rgba(255, 255, 255, 0.78);
        line-height: 1.6;
        font-size: 0.95rem;
    }

    .register-form-panel {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .register-card {
        width: 100%;
        max-width: 560px;
        border-radius: 30px;
        padding: 34px;
        background: rgba(255, 255, 255, 0.84);
        border: 1px solid rgba(226, 232, 240, 0.95);
        box-shadow: 0 22px 50px rgba(15, 23, 42, 0.10);
        backdrop-filter: blur(14px);
    }

    .register-card-header {
        margin-bottom: 26px;
    }

    .register-mini-badge {
        display: inline-flex;
        padding: 7px 12px;
        border-radius: 999px;
        background: #e0ecff;
        color: #1d4ed8;
        font-size: 0.84rem;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .register-card-header h2 {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .register-card-header p {
        margin: 0;
        color: #64748b;
        line-height: 1.7;
    }

    .validation-summary {
        margin-bottom: 18px;
        border-radius: 16px;
        padding: 12px 14px;
        background: #fff1f2;
        border: 1px solid #fecdd3;
        color: #be123c;
    }

        .validation-summary:empty {
            display: none;
        }

    .form-group-modern {
        margin-bottom: 18px;
    }

    .form-label-modern {
        display: inline-block;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .form-control-modern {
        width: 100%;
        min-height: 54px;
        border: 1px solid #dbe3ef;
        border-radius: 16px;
        padding: 0 16px;
        font-size: 1rem;
        color: #0f172a;
        background: rgba(255, 255, 255, 0.95);
        transition: all 0.2s ease;
        box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.03);
    }

        .form-control-modern:focus {
            outline: none;
            border-color: #60a5fa;
            box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.18);
            background: #fff;
        }

        .form-control-modern::placeholder {
            color: #94a3b8;
        }

    .form-select-modern {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        padding-right: 46px;
        background-image: linear-gradient(45deg, transparent 50%, #64748b 50%), linear-gradient(135deg, #64748b 50%, transparent 50%);
        background-position: calc(100% - 22px) calc(50% - 3px), calc(100% - 16px) calc(50% - 3px);
        background-size: 6px 6px, 6px 6px;
        background-repeat: no-repeat;
    }

    .text-danger {
        display: block;
        margin-top: 7px;
        font-size: 0.9rem;
    }

    .btn-register-modern {
        width: 100%;
        min-height: 56px;
        border: none;
        border-radius: 18px;
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 0.2px;
        box-shadow: 0 16px 30px rgba(37, 99, 235, 0.22);
        transition: all 0.2s ease;
        margin-top: 6px;
    }

        .btn-register-modern:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 34px rgba(37, 99, 235, 0.28);
        }

    .register-divider {
        display: flex;
        align-items: center;
        gap: 14px;
        margin: 24px 0 18px;
        color: #94a3b8;
        font-size: 0.92rem;
        font-weight: 700;
    }

        .register-divider::before,
        .register-divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

    .register-links {
        display: grid;
        gap: 12px;
    }

    .secondary-link-card {
        display: flex;
        flex-direction: column;
        gap: 4px;
        text-decoration: none;
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        background: #f8fbff;
        transition: all 0.2s ease;
    }

        .secondary-link-card strong {
            color: #0f172a;
            font-size: 0.98rem;
        }

        .secondary-link-card span {
            color: #64748b;
            font-size: 0.92rem;
            line-height: 1.5;
        }

        .secondary-link-card:hover {
            transform: translateY(-2px);
            border-color: #bfdbfe;
            background: #f0f7ff;
        }

    @@media (max-width: 1199.98px) {
        .register-shell {
            grid-template-columns: 1fr;
        }

        .register-brand-panel,
        .register-card {
            border-radius: 26px;
        }
    }

    @@media (max-width: 767.98px) {
        .register-page {
            min-height: auto;
            padding: 18px 0 30px;
        }

        .register-brand-panel,
        .register-card {
            padding: 24px;
        }

            .register-brand-panel h1 {
                font-size: 2.1rem;
            }

        .register-card-header h2 {
            font-size: 1.7rem;
        }
    }
</style>