@page
@model LogiDocs.Web.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="login-page">
    <div class="container">
        <div class="login-shell">

            <section class="login-brand-panel">
                <div class="brand-badge">LogiDocs</div>

                <h1>Welcome back</h1>

                <p class="brand-text">
                    Sign in to access your logistics and customs documents
                    in a secure, structured, and traceable environment.
                </p>

                <div class="brand-features">
                    <div class="brand-feature">
                        <span class="feature-icon">📄</span>
                        <div>
                            <strong>Document management</strong>
                            <p>Organize and access transport documents from one place.</p>
                        </div>
                    </div>

                    <div class="brand-feature">
                        <span class="feature-icon">🔒</span>
                        <div>
                            <strong>Secure access</strong>
                            <p>Role-based authentication for controlled platform usage.</p>
                        </div>
                    </div>

                    <div class="brand-feature">
                        <span class="feature-icon">⛓️</span>
                        <div>
                            <strong>Traceability</strong>
                            <p>Track document actions and preserve data integrity.</p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="login-form-panel">
                <div class="login-card">
                    <div class="login-card-header">
                        <div class="login-mini-badge">Account access</div>
                        <h2>Log in to your account</h2>
                        <p>
                            Enter your credentials to continue to the LogiDocs platform.
                        </p>
                    </div>

                    <form id="account" method="post" asp-route-returnUrl="@Model.ReturnUrl">
                        <div asp-validation-summary="ModelOnly" class="validation-summary text-danger" role="alert"></div>

                        <div class="form-group-modern">
                            <label asp-for="Input.Email" class="form-label-modern"></label>
                            <input asp-for="Input.Email"
                                   class="form-control-modern"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="Enter your email" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Input.Password" class="form-label-modern"></label>
                            <input asp-for="Input.Password"
                                   class="form-control-modern"
                                   autocomplete="current-password"
                                   aria-required="true"
                                   placeholder="Enter your password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="login-options">
                            <label asp-for="Input.RememberMe" class="remember-box">
                                <input asp-for="Input.RememberMe" class="remember-input" />
                                <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="btn-login-modern">
                            Log in
                        </button>

                        <div class="login-divider">
                            <span>Navigation</span>
                        </div>

                        <div class="login-links">
                            <a asp-page="/Index" class="secondary-link-card">
                                <strong>Back to dashboard</strong>
                                <span>Return to the main LogiDocs page.</span>
                            </a>

                            <a asp-page="/Privacy" class="secondary-link-card">
                                <strong>Privacy policy</strong>
                                <span>Read how LogiDocs handles data and confidentiality.</span>
                            </a>
                        </div>
                    </form>
                </div>
            </section>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .login-page {
        min-height: calc(100vh - 80px);
        padding: 32px 0;
        display: flex;
        align-items: center;
        background: radial-gradient(circle at top left, rgba(59, 130, 246, 0.14), transparent 28%), radial-gradient(circle at bottom right, rgba(16, 185, 129, 0.10), transparent 26%), linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    }

    .login-shell {
        width: 100%;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 28px;
        align-items: stretch;
    }

    .login-brand-panel {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 42px;
        background: linear-gradient(145deg, #0f172a 0%, #172554 55%, #2563eb 100%);
        color: #fff;
        box-shadow: 0 24px 70px rgba(15, 23, 42, 0.22);
    }

    .brand-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.16);
        font-size: 0.9rem;
        font-weight: 700;
        margin-bottom: 24px;
        backdrop-filter: blur(8px);
    }

    .login-brand-panel h1 {
        font-size: 2.8rem;
        line-height: 1.1;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .brand-text {
        max-width: 560px;
        color: rgba(255, 255, 255, 0.84);
        font-size: 1.05rem;
        line-height: 1.8;
        margin-bottom: 34px;
    }

    .brand-features {
        display: grid;
        gap: 16px;
        margin-top: 20px;
    }

    .brand-feature {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 18px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.10);
        backdrop-filter: blur(8px);
    }

    .feature-icon {
        width: 44px;
        height: 44px;
        min-width: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.14);
        font-size: 1.15rem;
    }

    .brand-feature strong {
        display: block;
        font-size: 1rem;
        margin-bottom: 4px;
    }

    .brand-feature p {
        margin: 0;
        color: rgba(255, 255, 255, 0.78);
        line-height: 1.6;
        font-size: 0.95rem;
    }

    .login-form-panel {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        width: 100%;
        max-width: 560px;
        border-radius: 30px;
        padding: 34px;
        background: rgba(255, 255, 255, 0.84);
        border: 1px solid rgba(226, 232, 240, 0.95);
        box-shadow: 0 22px 50px rgba(15, 23, 42, 0.10);
        backdrop-filter: blur(14px);
    }

    .login-card-header {
        margin-bottom: 26px;
    }

    .login-mini-badge {
        display: inline-flex;
        padding: 7px 12px;
        border-radius: 999px;
        background: #e0ecff;
        color: #1d4ed8;
        font-size: 0.84rem;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .login-card-header h2 {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .login-card-header p {
        margin: 0;
        color: #64748b;
        line-height: 1.7;
    }

    .validation-summary {
        margin-bottom: 18px;
        border-radius: 16px;
        padding: 12px 14px;
        background: #fff1f2;
        border: 1px solid #fecdd3;
        color: #be123c;
    }

        .validation-summary:empty {
            display: none;
        }

    .form-group-modern {
        margin-bottom: 18px;
    }

    .form-label-modern {
        display: inline-block;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .form-control-modern {
        width: 100%;
        min-height: 54px;
        border: 1px solid #dbe3ef;
        border-radius: 16px;
        padding: 0 16px;
        font-size: 1rem;
        color: #0f172a;
        background: rgba(255, 255, 255, 0.95);
        transition: all 0.2s ease;
        box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.03);
    }

        .form-control-modern:focus {
            outline: none;
            border-color: #60a5fa;
            box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.18);
            background: #fff;
        }

        .form-control-modern::placeholder {
            color: #94a3b8;
        }

    .text-danger {
        display: block;
        margin-top: 7px;
        font-size: 0.9rem;
    }

    .login-options {
        margin-top: 6px;
        margin-bottom: 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
    }

    .remember-box {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: #334155;
        font-weight: 600;
        cursor: pointer;
    }

    .remember-input {
        width: 18px;
        height: 18px;
        accent-color: #2563eb;
    }

    .btn-login-modern {
        width: 100%;
        min-height: 56px;
        border: none;
        border-radius: 18px;
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 0.2px;
        box-shadow: 0 16px 30px rgba(37, 99, 235, 0.22);
        transition: all 0.2s ease;
    }

        .btn-login-modern:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 34px rgba(37, 99, 235, 0.28);
        }

    .login-divider {
        display: flex;
        align-items: center;
        gap: 14px;
        margin: 24px 0 18px;
        color: #94a3b8;
        font-size: 0.92rem;
        font-weight: 700;
    }

        .login-divider::before,
        .login-divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

    .login-links {
        display: grid;
        gap: 12px;
    }

    .secondary-link-card {
        display: flex;
        flex-direction: column;
        gap: 4px;
        text-decoration: none;
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        background: #f8fbff;
        transition: all 0.2s ease;
    }

        .secondary-link-card strong {
            color: #0f172a;
            font-size: 0.98rem;
        }

        .secondary-link-card span {
            color: #64748b;
            font-size: 0.92rem;
            line-height: 1.5;
        }

        .secondary-link-card:hover {
            transform: translateY(-2px);
            border-color: #bfdbfe;
            background: #f0f7ff;
        }

    @@media (max-width: 1199.98px) {
        .login-shell {
            grid-template-columns: 1fr;
        }

        .login-brand-panel,
        .login-card {
            border-radius: 26px;
        }
    }

    @@media (max-width: 767.98px) {
        .login-page {
            min-height: auto;
            padding: 18px 0 30px;
        }

        .login-brand-panel,
        .login-card {
            padding: 24px;
        }

            .login-brand-panel h1 {
                font-size: 2.1rem;
            }

        .login-card-header h2 {
            font-size: 1.7rem;
        }
    }

    @@media (max-width: 575.98px) {
        .login-options {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>